<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {%- if title %}
  <title>{{ title }} — {{ site.title }}</title>
  {%- else %}
  <title>{{ site.title }} — {{ site.tagline }}</title>
  {%- endif %}
  <meta name="description" content="{{ description or site.description }}">

  {#- Favicon set: deep-bg variants validated in real browser tab Session 12.
      Pastel watercolour on a transparent background washes out on light browser
      tab chrome at 16-32 px; the --lotus-deep #765E55 backdrop fixes contrast. -#}
  <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon_16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon_32x32.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon_180x180.png">

  {#- Cloudflare Web Analytics — replace BEACON_TOKEN once the property is
      enrolled at dash.cloudflare.com → Web Analytics → Add a site (manual
      setup mode, not the proxy mode that requires DNS at Cloudflare). Until
      enrolled, the snippet stays commented out and no analytics are collected. -#}
  {#-
  <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "BEACON_TOKEN"}'></script>
  -#}

  {#- Source Serif 4 from Google Fonts — locked typeface (Session 4 / Session 5).
      Weights loaded: 400 (Regular, the locked wordmark + body weight) and 600
      (SemiBold, available in case headings or emphasis want it during Stage 2).
      display=swap means text renders in the Georgia fallback immediately and
      swaps to Source Serif when it arrives — no flash of invisible text.
      preconnect saves a round-trip vs letting the browser discover gstatic.com
      through the stylesheet itself. -#}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:wght@400;600&display=swap">

  {#- Site stylesheet — palette tokens + typography + wordmark spec. -#}
  <link rel="stylesheet" href="/assets/styles.css">
</head>
<body{% if page.url == '/' %} class="home"{% endif %}>
  <a class="visually-hidden" href="#main">Skip to main content</a>

  <header>
    <a href="/" class="wordmark">
      <img src="/assets/lotus_icon.png" alt="" width="180" height="180" class="wordmark-icon">
      <span class="wordmark-text">{{ site.title }}</span>
    </a>
    <nav aria-label="Primary">
      <ul>
        {%- for item in site.nav %}
        <li><a href="{{ item.url }}">{{ item.label }}</a></li>
        {%- endfor %}
      </ul>
    </nav>
  </header>

  <main id="main">
    {{ content | safe }}
  </main>

  <footer>
    <p>
      <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      &nbsp;·&nbsp;
      <a href="/privacy/">Privacy &amp; policies</a>
    </p>
    <p>&copy; {% year %} {{ site.title }}.</p>
  </footer>
</body>
</html>
